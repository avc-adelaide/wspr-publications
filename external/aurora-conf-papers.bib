@inproceedings{schubert2018pseudononlinearconverters,
address = {online},
author = {Schubert, B and Meng, F and Sergiienko, N and Robertson, W and Cazzolato, B and Ghayesh, M and Rafiee, A and Ding, B and Arjomandi, M},
booktitle = {Proceedings of the 4th Asian Wave and Tidal Energy Conference (AWTEC 2018)},
number = {442},
organization = {Taipei, Taiwan},
pages = {1--10},
publisher = {AWTEC},
title = {Pseudo-nonlinear hydrodynamic coefficients for modelling point absorber wave energy converters},
url = {https://tethys.pnnl.gov/events/4th-asian-wave-tidal-energy-conference-awtec},
year = {2018},
abstract = {This study presents dynamic simulation results of two point absorber wave energy converters comparing between linear, pseudo-nonlinear, and CFD models. When modelling wave energy converters, linear assumptions are commonly used to simplify calculations. One such assumption is that the hydrody- namic parameters do not change with pose. This study proposes the inclusion of position and orientation dependence in force estimation, specifically the hydrodynamic terms. A comparison between linear, the proposed pseudo-nonlinear, and CFD models show the effect of the linear assumption for cylindrical and spherical submerged buoys in three degrees of freedom, subject to regular waves. For the case of strong nonlinear hydrodynamic coupling between degrees of freedom, the linear and pseudo- nonlinear models are compared with published literature trends. Accounting for pose dependence of hydrodynamic forces, drag forces, and infinite frequency inertial effects showed trends closer to CFD results but with generally higher motion amplitudes. Significant differences in results for the cylinder are due to the presence of near-surface nonlinear effects that are not captured using linear potential flow solvers. Furthermore, a second order effect was observed in the results, suggesting the proposed method may be well suited to model sufficiently submerged buoys.},
startyear = {2018},
startmonth = {Sep},
startday = {9},
finishyear = {2018},
finishmonth = {Sep},
finishday = {13},
keyword = {Submerged point absorber; nonlinear hydro- dynamics; numerical wave tank; wave energy converter; linear parameter varying},
language = {en},
conference = {4th Asian Wave and Tidal Energy Conference (AWTEC)},
publicationstatus = {published},
}
