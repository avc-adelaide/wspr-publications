@inproceedings{sobey2016adevice,
author = {Sobey, SA and Grimshaw, PN and Grainger, S and Robertson, WS and Taylor, I and Weston, M},
booktitle = {INTELLIGENT ENVIRONMENTS 2016},
editor = {Novais, P and Konomi, S},
month = {Jan},
organization = {London, ENGLAND},
pages = {570--576},
publisher = {IOS PRESS},
series = {Ambient Intelligence and Smart Environments},
title = {A Low Cost, Wireless Spinal Motion Measurement Device},
url = {http://gateway.webofknowledge.com/gateway/Gateway.cgi?GWVersion=2\&SrcApp=PARTNER_APP\&SrcAuth=LinksAMR\&KeyUT=WOS:000390309400068\&DestLinkType=FullRecord\&DestApp=ALL_WOS\&UsrCustomerID=1f051b2c0ced71d786748f61000f9895},
url = {https://doi.org/10.3233/978-1-61499-690-3-570},
volume = {21},
year = {2016},
abstract = {<jats:p>In this study, a low cost Spinal Motion Measurement device (SMM) was created. The device consists of up to three inertial measurement units (IMUs) and two accelerometers. The IMUs are primarily used to measure the orientation and angular rate of the spine, however they can also be used on other body segments. The accelerometers are used to determine if the user is standing or sitting. The SMM uses inexpensive IMUs that are comparable in orientation accuracy to more expensive IMUs and optical motion capture in axes perpendicular to gravity. The SMM is capable of logging data at a maximum frequency of ~55Hz and has a wireless range of 15m. The SMM has shown potential to be a useful, low cost alternative for the collection of human movement data.</jats:p>},
doi = {10.3233/978-1-61499-690-3-570},
startyear = {2016},
startmonth = {Sep},
startday = {12},
