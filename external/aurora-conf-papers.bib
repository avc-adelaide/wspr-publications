title = {Resolving Bellhop Issues: Negative Range Arrivals and Volume Attenuation},
url = {https://www.acoustics.asn.au/conference_proceedings/AAS2025},
year = {2025},
abstract = {Bellhop is a widely used underwater acoustic ray-tracing model, but its 1990s Fortran core imposes legacy constraints including half-space simulations and single-frequency absorption. We identify and correct a key numerical issue in the ArrMod.f90 module that prevented negative-range propagation, enabling single-run full-space simulations without separate half space runs. In addition, we extended Bellhop's single frequency ab-sorption to broadband application by post processing along individual ray trajectories at lower computational cost. Validation against analytical solution shows agreement in both positive and negative ranges and accurate frequency-dependent attenuation. These improvements simplify Bellhop workflows and provide a more general-ised volume attenuation solution.},
startyear = {2025},
startmonth = {Nov},
startday = {12},
finishyear = {2025},
finishmonth = {Nov},
finishday = {14},
keyword = {Bellhop, acoustic ray-tracing mode},
language = {en},
conference = {Acoustics: Sounds of the Sunset Coast},
day = {15},
publicationstatus = {published},
}
